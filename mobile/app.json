{
  "expo": {
    "name": "StillMind",
    "slug": "stillmind-inner-cinema",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/stillmind-icon.png",
    "scheme": "stillmind",
    "userInterfaceStyle": "dark",
    "ios": {
      "icon": "./assets/images/stillmind-icon.png",
      "bundleIdentifier": "com.stillmind.innercinema",
      "supportsTablet": false,
      "infoPlist": {
        "NSUserNotificationsUsageDescription": "StillMind 仅在你主动设置觉察锚点后发送本地提醒。"
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.stillmind.innercinema"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#050914",
          "image": "./assets/images/stillmind-icon.png",
          "imageWidth": 76,
          "android": {
            "image": "./assets/images/stillmind-icon.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-sqlite",
      "expo-sharing",
      "expo-notifications"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "apiBaseUrl": "https://stillmind-inner-cinema.vercel.app"
    }
  }
}
